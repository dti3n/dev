#!/usr/bin/env bash

languages=(
    javascript
    typescript
    tsx
    jsdoc
    bash
    go
    ruby
    java
)

TREE="$HOME/.local/share/nvim/rocks"
LUA_VERSION=$(lua -v 2>&1 | grep -oE '[0-9]+\.[0-9]+' | head -n1)
ROCKS_BASE="$HOME/.local/share/nvim/rocks/lib/luarocks/rocks-$LUA_VERSION"

SITE_PARSER="$HOME/.local/share/nvim/site/parser"
SITE_QUERIES="$HOME/.local/share/nvim/site/queries"

for lang in "${languages[@]}"; do
    echo "installing tree-sitter-$lang"
    echo "> luarocks --lua-version=$LUA_VERSION --tree=$TREE install tree-sitter-$lang"
    luarocks \
        --lua-version=$LUA_VERSION \
        --tree=$TREE \
        install tree-sitter-$lang
    echo
done

echo "done install"
echo
echo

# ============================================================================= 

mkdir -p "$SITE_PARSER"
mkdir -p "$SITE_QUERIES"

rocks=$(luarocks list --tree="$TREE" | grep -oE 'tree-sitter-[a-zA-Z1-9_]+' | sort -u)

for rock in $rocks; do
    lang="${rock#tree-sitter-}"

    echo "linking $rock"

    version_dir=$(find "$ROCKS_BASE/$rock" -maxdepth 1 -type d -name '[0-9]*' 2>/dev/null | sort -V | tail -n 1)
    if [ -z "$version_dir" ] || [ ! -d "$version_dir" ]; then
        echo "no version found for $rock"
        echo
        continue
    fi

    parser_so="$version_dir/parser/${lang}.so"
    if [ -f "$parser_so" ]; then
        printf '> ln -sf %q %q\n' "$parser_so" "$SITE_PARSER/${lang}.so"
        ln -sf "$parser_so" "$SITE_PARSER/${lang}.so"
        echo ">> parser: ${lang}.so"
    else
        echo ">> no parser/${lang}.so found"
    fi

    queries_dir="$version_dir/queries/${lang}"
    if [ -d "$queries_dir" ]; then
        printf '> ln -sf %q %q\n' "$queries_dir" "$SITE_QUERIES/${lang}"
        ln -sf "$queries_dir" "$SITE_QUERIES/${lang}"
        echo ">> queries: ${lang}"
    else
        echo ">> no queries/${lang} found"
    fi

    echo "done"
    echo
done
